{
  "services": {
    "backend": {
      "root": "backend",
      "startCommand": "python -m uvicorn main:app --host 0.0.0.0 --port $PORT"
    },
    "frontend": {
      "root": "frontend",
      "startCommand": "npm run build && npm start"
    }
  },
  "variables": {
    "GEMINI_API_KEY": "",
    "SMTP_PASSWORD": "",
    "DATABASE_URL": "sqlite:///./data.db"
  }
}
